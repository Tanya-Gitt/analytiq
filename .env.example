# ──────────────────────────────────────────────
# Unified Analytics Platform — environment vars
# Copy to .env and fill in values before running.
# ──────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────
# PostgreSQL superuser password (used by postgres service and GoTrue auth)
POSTGRES_PASSWORD=changeme

# Least-privilege app user password (used by FastAPI app and scheduler).
# Generate with: python -c "import secrets; print(secrets.token_hex(24))"
APP_DB_PASSWORD=changeme_app_db_password

# Secret key for JWT signing. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=changeme_generate_a_real_secret

# ── OPTIONAL: AI Copilot ─────────────────────
# Required for the AI Copilot feature (/copilot).
# Get yours at: console.groq.com
# GROQ_API_KEY=gsk_...

# ── OPTIONAL: SMTP email alerts ───────────────
# If not set, email alert rules log a warning and skip send.
# Platform starts and runs normally without these.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=alerts@example.com
# SMTP_PASS=your_smtp_password
# SMTP_FROM=alerts@example.com

# ── OPTIONAL: Slack alerts ────────────────────
# If not set, Slack alert rules log a warning and skip send.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── DERIVED (do not change unless you know what you're doing) ──
# Tests still connect as the superuser so RLS FORCE policies are bypassed correctly
# in the test harness (SET LOCAL ROLE app_role is called explicitly in each test).
TEST_DATABASE_URL=postgresql://analytics:${POSTGRES_PASSWORD}@localhost:5432/analytics_test
