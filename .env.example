# ──────────────────────────────────────────────
# Unified Analytics Platform — environment vars
# Copy to .env and fill in values before running.
# ──────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────
# PostgreSQL password (used by postgres service and app/scheduler)
POSTGRES_PASSWORD=changeme

# Secret key for JWT signing. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=changeme_generate_a_real_secret

# ── OPTIONAL: SMTP email alerts ───────────────
# If not set, email alert rules log a warning and skip send.
# Platform starts and runs normally without these.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=alerts@example.com
# SMTP_PASS=your_smtp_password
# SMTP_FROM=alerts@example.com

# ── OPTIONAL: Slack alerts ────────────────────
# If not set, Slack alert rules log a warning and skip send.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── DERIVED (do not change unless you know what you're doing) ──
DATABASE_URL=postgresql://analytics:${POSTGRES_PASSWORD}@postgres:5432/analytics
TEST_DATABASE_URL=postgresql://analytics:${POSTGRES_PASSWORD}@localhost:5432/analytics_test
