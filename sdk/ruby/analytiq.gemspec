Gem::Specification.new do |s|
  s.name        = 'analytiq'
  s.version     = '0.1.0'
  s.summary     = 'Server-side Ruby SDK for Analytics Platform'
  s.description = 'Track events, identify users, and record page views from your Ruby backend.'
  s.files       = Dir['lib/**/*.rb']
  s.require_paths = ['lib']
  s.required_ruby_version = '>= 2.7'
end
